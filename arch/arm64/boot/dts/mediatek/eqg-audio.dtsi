&spk {
	status = "disable";
};

&i2c7 {
        status = "okay";
        clock-frequency = <400000>;

        aw882xx_smartpa_rcv: aw882xx@34 {
                compatible = "awinic,aw882xx_smartpa";
                #sound-dai-cells = <0>;
                reg = <0x34>;
                irq-gpio = <&pio 20 0x0>;
                /*sync-load = <1>;*/
                sound-channel = <0>; /*0:pri_l 1:pri_r 2:sec_l 3:sec_r*/
                aw-re-min = <4000>;
                aw-re-max= <30000>;
                /*aw-cali-mode = "none";*/
                status = "okay";
        };
        aw882xx_smartpa_spk: aw882xx@35 {
                compatible = "awinic,aw882xx_smartpa";
                #sound-dai-cells = <0>;
                reg = <0x35>;
                irq-gpio = <&pio 19 0x0>;
                /*sync-load = <1>;*/
                sound-channel = <1>; /*0:pri_l 1:pri_r 2:sec_l 3:sec_r*/
                aw-re-min = <4000>;
                aw-re-max= <30000>;
                /*aw-cali-mode = "none";*/
                status = "okay";
        };
};

&sound {
        mediatek,spk-i2s = <21 20>;
        mediatek,speaker-codec {
                sound-dai = <&aw882xx_smartpa_rcv &aw882xx_smartpa_spk>;
        };
};

&afe {
        mediatek,ap-dmic = <0>;
};

&i2c13 {
        status = "okay";
        clock-frequency = <400000>;

        fsa4480: fsa4480@42 {
                compatible = "fsa,fsa4480-i2c";
                reg = <0x42>;
                status = "okay";
        };
};
