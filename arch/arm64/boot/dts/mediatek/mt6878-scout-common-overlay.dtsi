#include "mediatek/mt6878-moto-common-overlay-single-panel.dtsi"

#include "mediatek/cust_scout_camera_v4l2.dtsi"
#include "mediatek/scout-charger.dtsi"
#include "mediatek/scout-fps.dtsi"
#include "mediatek/scout-ntc.dtsi"
#include "mediatek/scout-display.dtsi"
#include "mediatek/scout-touch.dtsi"

#include <dt-bindings/gpio/gpio.h>

&pio {
	nfc_spi_cs_mode_spi: nfc_spi_cs_mode_spi {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO73__FUNC_SPI5_CSB>;
			bias-disable;
		};
	};

	nfc_spi_cs_mode_idle: nfc_spi_cs_mode_idle {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO73__FUNC_GPIO73>;
			bias-disable;
		};
	};

	sar_int_default: sar_int_default {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO114__FUNC_GPIO114>;
			input-enable;
			drive-strength = <2>;
			bias-pull-up;
		};
	};

	sar_int_sleep: sar_int_sleep {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO114__FUNC_GPIO114>;
			input-enable;
			drive-strength = <2>;
			bias-pull-up;
		};
	};

	i2c12_mode_default: i2c12_mode_default {
		pins_cmd_dat {
			pinmux = <PINMUX_GPIO53__FUNC_SCL12>,
				<PINMUX_GPIO52__FUNC_SDA12>;
			/*mt65xx.h PULL_UP 2.5k*/
			bias-pull-up = <202>;
		};
	};
};


&spi5 {
	p61: p61@0 {
		compatible = "nxp,p61";
		reg = <0>;
		spi-max-frequency = <10000000>;
		nxp,nfcc = "10-0029";
//		nxp,p61-rst = <&gpio2 5 0>;
		pinctrl-names = "pinctrl_state_mode_spi",
				"pinctrl_state_mode_idle";
		pinctrl-0 = <&nfc_spi_cs_mode_spi>;
		pinctrl-1 = <&nfc_spi_cs_mode_idle>;
		status = "okay";
	};
};

&u2port0{
	mediatek,eye-vrt = <4>;
	mediatek,eye-vrt-host = <4>;
	mediatek,eye-term = <4>;
	mediatek,eye-term-host = <4>;
	mediatek,rev6 = <3>;
	mediatek,rev6-host = <3>;
};

&rt5133 {
	status = "disabled";
};

//for alsps sensor
&mt6369_vio28 {
	regulator-min-microvolt = <3300000>;
	regulator-max-microvolt = <3300000>;
	regulator-always-on;
};

&mt6363_vio18 {
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <2100000>;
};

&i2c10 {
	status = "ok";
	st21nfc: st21nfc@0x08 {
		compatible = "st,st21nfc";
		reg = <0x08>;
		interrupt-parent = <&pio>;
		interrupts = <2 0>;
		bootmode = <&chosen>;
		reset-gpios = <&pio 40 0x00>;
		irq-gpios = <&pio 2 0x00>;
		clkreq-gpios = <&pio 151 0x00>;
		status = "disabled";
	};
	nfc_pn5xx: nfc_pn5xx@29 {
		compatible = "qcom,sn-nci";
		reg = <0x29>;
		interrupt-parent = <&pio>;
		interrupts = <2 0>;
		qcom,sn-irq = <&pio 2 0>;
		qcom,sn-ven = <&pio 40 0>;
		status = "okay";
	};

	sx937x: sx937x@2c { /* SAR sensor */
		compatible = "Semtech,sx937x";
		reg = <0x2c>;
		Semtech,power-supply-type = <0>;
		cap_vdd-supply = <&mt6363_vio18>;
		pinctrl-names = "default","sleep";
		pinctrl-0 = <&sar_int_default>;
		pinctrl-1 = <&sar_int_sleep>;
		interrupt-parent = <&pio>;
		interrupts = <114 0x02>;
		interrupt-names = "sx937x_irq";
		Semtech,nirq-gpio= <&pio 114 0x02>;
		esd-reinit-on = <1>;
		/*use PH5/6 as the reference sensor
		set it to 0xff if the ref-phases-x is not used*/
		Semtech,ref-phases-a = <4>;
		Semtech,ref-phases-b = <5>;
		Semtech,ref-phases-c = <6>;
		Semtech,button-flag = <0x0f>;
		Semtech,reg-num = <59>;
		Semtech,reg-init = <
			0x8024 0x00007F00
			0x4004 0x00000074
			0x4008 0x00000008
			0x8020 0x00000032
			0x8028 0x0000085E    /*AFE_PARAM_PH0*/
			0x8034 0x0000085F    /*AFE_PARAM_PH1*/
			0x8040 0x0000085E    /*AFE_PARAM_PH2*/
			0x804C 0x0000085E    /*AFE_PARAM_PH3*/
			0x8058 0x0000085E    /*AFE_PARAM_PH4*/
			0x8064 0x0000085E    /*AFE_PARAM_PH5*/
			0x8070 0x0000085E    /*AFE_PARAM_PH6*/
			0x807C 0x0000085E    /*AFE_PARAM_PH7*/
			/*set CS3 to HZ, because it used as IRQ pin*/
			0x8030 0x00924925    /*REG_AFEPH_PH0, CS0, ANT0*/
			0x803C 0x0092C924    /*REG_AFEPH_PH1, CS5, ANT1*/
			0x8048 0x00964924    /*REG_AFEPH_PH2, CS6, ANT3/4/5*/
			0x8054 0x00B24924    /*REG_AFEPH_PH3, CS7, ANT2*/
			0x8060 0x0092492C    /*REG_AFEPH_PH4, CS1, ANT0_REF*/
			0x806C 0x00924964    /*REG_AFEPH_PH5, CS2, ANT3/4/5 REF*/
			0x8078 0x00925924    /*REG_AFEPH_PH6, CS4, ANT1 REF*/
			0x8084 0x00B24924    /*REG_AFEPH_PH7, NOT USE*/
			0x8098 0x00006239
			0x80B8 0x00005130
			0x80D8 0x00004630
			0x80F8 0x00002525
			0x8118 0x000000FF
			0x8138 0x000000FF
			0x8158 0x000000FF
			0x8178 0x000000FF
			0x80A0 0x1D1D0001
			0x80C0 0x1D1D0003
			0x80E0 0x5F5F0002
			0x8100 0x24240001
			0x8188 0x08000004
			0x818C 0x08000005
			0x8190 0x08000006
			0x8090 0x54AC5000
			0x80B0 0x34CC5000
			0x80D0 0x54AC5000
			0x80F0 0x30D05000
			0x8110 0x54AC5000
			0x8130 0x54AC5000
			0x8150 0x54AC5000
			0x8170 0x54AC5000
			0x8088 0x00300000
			0x80A8 0x00300000
			0x80C8 0x00300000
			0x80E8 0x00300000
			0x8108 0x06300000
			0x8128 0x06300000
			0x8148 0x06300000
			0x8168 0x06300000
			0x808C 0x60200030
			0x80AC 0x60200030
			0x80CC 0x60200030
			0x80EC 0x60200030
			0x810C 0x60200030
			0x812C 0x60200030
			0x814C 0x60200030
			0x816C 0x60200030
		>;
		status = "okay";
	};

	stk501xx: stk501xx@28 { /* SAR sensor */
		compatible = "mediatek,stk501xx";
		reg = <0x28>;
		pinctrl-names = "default","sleep";
		pinctrl-0 = <&sar_int_default>;
		pinctrl-1 = <&sar_int_sleep>;
		stk,direction = "in";
		interrupt-parent = <&pio>;
		interrupts = <114 0x02>;
		interrupt-names = "stk501xx_irq";
		stk501xx,irq-gpio = <&pio 114 0x02>;
		ch_num = <4>;
		major_phase = <0 1 1 0 1 0 1 0>; //major phase set to '1'
		ref_phase   = <1 0 0 1 0 1 0 0>; //reference phase set to '1'
		mapping_phase = <1 4 6 2 0 3 5 7>;
		dist1_en = <0 1 0 0 1 0 0 0>; // enable dist1
		dist0_thd = <90000 1300 500 90000 1600 90000 780 90000>;
		dist1_thd = <90000 8000 90000 90000 8000 90000 5000 90000>;
		tc_config_a = <44000 0 1 1 2 255>; //temp_delta_thd, ,maping_ref_ph, major_ph, base_reinit_ph_1, base_reinit_ph_2, base_reinit_ph_3
		tc_config_b = <9500 3 4 4 255 255>; //temp_delta_thd, ,maping_ref_ph, major_ph, base_reinit_ph_1, base_reinit_ph_2, base_reinit_ph_3
		tc_config_c = <4000 5 6 6 255 255>; //temp_delta_thd, ,maping_ref_ph, major_ph, base_reinit_ph_1, base_reinit_ph_2, base_reinit_ph_3
		tc_ctrl_des_a = <409 3 3>; //delta_ctrl_thd, delta_deb_clr, delta_deb_set
		tc_ctrl_des_b = <358 3 3>; //delta_ctrl_thd, delta_deb_clr, delta_deb_set
		tc_ctrl_des_c = <307 3 3>; //delta_ctrl_thd, delta_deb_clr, delta_deb_set
		rxio_map = < //usage: 0=OPT, 1=HZ, 2=GND, 3=SHIELD, 4=MEASUER
			4 4	//RXIO_0 mappint to (phase_idx, usage)
			5 4	//RXIO_1 mappint to (phase_idx, usage)
			0 4	//RXIO_2 mappint to (phase_idx, usage)
			0 0	//RXIO_3 is INT, don't change
			3 4	//RXIO_4 mappint to (phase_idx, usage)
			6 4	//RXIO_5 mappint to (phase_idx, usage)
			2 4	//RXIO_6 mappint to (phase_idx, usage)
			1 4	//RXIO_7 mappint to (phase_idx, usage)
		>;
		replace_reg_num = <139>;
		replace_reg_val = <
			0x104 0x0
			0x100 0xf
			0xa00 0xa
			0x10 0xa5
			0x768 0x110010
